# --- Supabase ---
# 在 https://supabase.com 创建项目后，从 Project Settings → API 复制
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Edge Functions URL（用于代理高德 POI 等敏感请求）
# 格式：https://<project-ref>.supabase.co/functions/v1
VITE_SUPABASE_FUNCTIONS_URL=

# --- POI Provider ---
# mock: 使用本地假数据（P0 默认）
# amap: 前端直连高德 Web 服务 API（Key 会暴露在前端 bundle 中）
# edge: 通过 Supabase Edge Function 代理高德请求（推荐，Key 不暴露）
VITE_POI_PROVIDER=mock
VITE_AMAP_KEY=

# --- Dev: 放行模式（本地 npm run dev 默认已开，下面一般不用动）---
# 只有想关掉时才设 false；生产构建不会启用，与这里无关。
# VITE_AUTH_LAX_DEV=false
# 想在 dev 里强制走真实登录页（不测放行）：设其一即可
# VITE_AUTH_STRICT_AUTH=true
# VITE_AUTH_LAX_DEV=false

# --- Dev: fixture user auto-login（可选，与真实账号流程可同时存在）---
# 仅当下方开关为 true 时才会在未登录时用 fixture 帐号自动登录；
# 未开启时仍可走 /auth 页面手动登录或在「我的」登录。
VITE_FIXTURE_AUTO_LOGIN=false
# 在 Supabase Dashboard → Authentication → Users 创建一个测试用户后填入
VITE_FIXTURE_EMAIL=
VITE_FIXTURE_PASSWORD=

# --- 账号：研发邮箱 Tab（主页为手机号+密码）；生产可保持 false ---
VITE_ENABLE_EMAIL_AUTH=false

# --- 举报测试：在 TestFlight/测试包里临时显示假店评/假菜评；正式上线前务必删除或设为 false ---
VITE_ENABLE_REPORT_TEST_FIXTURES=false
